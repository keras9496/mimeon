# 공공데이터포털 에어코리아 API 키 (https://www.data.go.kr/)
# 이 파일은 템플릿 — 실제 키는 절대 여기에 넣지 말 것.
# .env 파일을 별도로 만들어 실제 키를 넣으면 앱이 읽습니다 (.env 는 .gitignore 에 포함됨).
AIRKOREA_API_KEY=your_api_key_here

# 카카오 Local REST API 키 — MCP tool 의 서버 지오코딩(장소명→좌표)용.
# 프론트의 JS 키(VITE_KAKAO_MAP_KEY)와는 다른 키. 카카오 개발자 콘솔 → 앱 키 → REST API 키.
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Frontend
VITE_API_BASE_URL=http://localhost:8000
